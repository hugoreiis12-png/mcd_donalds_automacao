# ── Banco de Dados (prefixo PG_) ──
PG_HOST=192.168.0.250
PG_PORT=5432
PG_DBNAME=FABRICA
PG_USER=postgres
# Producao: dados e auditoria em public (public.mcd_reclamacao + public.pipeline_auditoria)
PG_SCHEMA=public

# Senha do banco:
# - Producao (Docker/Portainer): NAO defina aqui. Use um Docker secret com
#   PG_PASSWORD_FILE=/run/secrets/pg_password (ver docker-compose.yml).
# - Dev local: defina PG_PASSWORD abaixo OU crie o arquivo secrets/pg_password.
PG_PASSWORD=

# ── Credenciais do portal Martin Brower ──
LOGIN_USER=
LOGIN_PASSWORD=

# ── Pipeline ──
BASE_DIR=./dados
LOGIN_URL=https://portal.martinbrower.com.br/mbbr/security-app/login
SITE_URL=https://portal.martinbrower.com.br/mbbr/crmfornec/#/home
HEADLESS=true
DOWNLOAD_TIMEOUT=120
CANAL=console
# Data inicial da extracao (ISO YYYY-MM-DD). Vazio = 01/01 do ano corrente.
DT_INICIO_EXTRACAO=
