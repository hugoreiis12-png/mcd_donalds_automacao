# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Virtualenv
.venv/
venv/

# Cache
.mypy_cache/
.pytest_cache/

# Dados gerados pela pipeline
dados/xlsx/
dados/csv/
dados/logs/

# Dumps/amostras de dados do servidor (nao versionar — arquivos grandes)
modulos_server/

# Configuracao local (contem senhas) — nenhum .env vai ao git, exceto o exemplo
.env
.env.*
!.env.example

# Secrets (arquivos de senha) — apenas exemplos e o .gitignore vao para o git
secrets/*
!secrets/.gitignore
!secrets/*.example

# IDE
.vscode/
.idea/
